    "sequence": 23,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000022",
    "text": "Q & A: tested using top K (number of chunks retrieved) and Cosine threshold (filters relevant content based on similarity score).",
    "page_number": 1,
    "bounding_box": {
