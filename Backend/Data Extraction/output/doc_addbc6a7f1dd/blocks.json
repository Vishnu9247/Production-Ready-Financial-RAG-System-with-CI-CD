    "document_id": "doc_addbc6a7f1dd",
    "sequence": 12,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000011",
    "text": "o Concise, high-quality summaries",
    "page_number": 1,
    "bounding_box": {
      "left": 36.12,
      "top": 2439.9500000000003,
      "right": 589.4705600000002,
      "bottom": 2401.91
    },
    "label": "list_item"
  },
