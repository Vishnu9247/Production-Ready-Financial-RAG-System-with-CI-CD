    "document_id": "doc_addbc6a7f1dd",
    "sequence": 10,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000009",
    "text": "Manual skimming is inefficient and time-consuming.",
    "page_number": 1,
    "bounding_box": {
      "left": 58.68,
      "top": 2531.15,
      "right": 864.59444,
      "bottom": 2493.1099999999997
    },
    "label": "list_item"
  },
  {
    "block_id": "doc_addbc6a7f1dd_block_000011",
    "document_id": "doc_addbc6a7f1dd",
    "sequence": 11,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000010",
    "text": "There's a growing demand for:",
    "page_number": 1,
    "bounding_box": {
      "left": 36.12,
      "top": 2485.55,
      "right": 529.6151999999998,
      "bottom": 2447.5099999999998
