    "sequence": 6,
    "type": "heading",
    "text_id": "doc_addbc6a7f1dd_text_000005",
    "text": "The Problem (Introduction):",
    "heading_level": 1,
    "page_number": 1,
    "bounding_box": {
      "left": 36.12,
      "top": 2759.15,
      "right": 476.35692,
      "bottom": 2721.1099999999997
