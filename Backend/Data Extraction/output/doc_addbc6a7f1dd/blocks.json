    "document_id": "doc_addbc6a7f1dd",
    "sequence": 16,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000015",
    "text": "Provide precise answers to user-defined questions.",
    "page_number": 1,
    "bounding_box": {
      "left": 36.12,
      "top": 2186.5400000000004,
      "right": 833.82824,
      "bottom": 2148.5
    },
    "label": "list_item"
  },
