    "document_id": "doc_addbc6a7f1dd",
    "sequence": 15,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000014",
    "text": "Automatically generate summaries for YouTube videos.",
    "page_number": 1,
