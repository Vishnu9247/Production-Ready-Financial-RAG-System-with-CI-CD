  },
  {
    "block_id": "doc_addbc6a7f1dd_block_000026",
    "document_id": "doc_addbc6a7f1dd",
    "sequence": 26,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000024",
    "text": "GPT-4 mini & GPT-3.5 Turbo lead in Q&A, with BERT scores > 0.90 at higher K values.",
    "page_number": 1,
    "bounding_box": {
      "left": 33.36,
      "top": 973.4099999999999,
      "right": 1377.775400000001,
      "bottom": 935.3699999999999
    },
    "label": "list_item"
  },
  {
    "block_id": "doc_addbc6a7f1dd_block_000027",
    "document_id": "doc_addbc6a7f1dd",
    "sequence": 27,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000025",
    "text": "Claude Sonnet shows stable performance across temperatures, maintaining ~0.85 BERT scores.",
    "page_number": 1,
    "bounding_box": {
      "left": 33.36,
      "top": 927.81,
      "right": 1431.9373200000016,
      "bottom": 844.1700000000001
    },
    "label": "list_item"
  },
  {
    "block_id": "doc_addbc6a7f1dd_block_000028",
    "document_id": "doc_addbc6a7f1dd",
    "sequence": 28,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000026",
    "text": "As K increases the performance also increases consistently for all models and there is no particular trend for cosine threshold.",
    "page_number": 1,
    "bounding_box": {
      "left": 33.36,
      "top": 836.6100000000001,
      "right": 1445.669760000001,
      "bottom": 752.9700000000003
