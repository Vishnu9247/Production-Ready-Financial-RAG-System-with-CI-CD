    "sequence": 9,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000008",
    "text": "·",
    "page_number": 1,
    "bounding_box": {
      "left": 36.12,
      "top": 2530.31312,
      "right": 49.434,
      "bottom": 2496.193972154696
    },
    "label": "list_item"
  },
  {
