    "label": "section_header"
  },
  {
    "block_id": "doc_addbc6a7f1dd_block_000007",
    "document_id": "doc_addbc6a7f1dd",
    "sequence": 7,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000006",
    "text": "Over 500 hours of videos are uploaded to YouTube every minute.",
    "page_number": 1,
    "bounding_box": {
      "left": 36.12,
      "top": 2713.55,
      "right": 845.57544,
      "bottom": 2629.91
    },
    "label": "list_item"
  },
  {
    "block_id": "doc_addbc6a7f1dd_block_000008",
    "document_id": "doc_addbc6a7f1dd",
    "sequence": 8,
    "type": "text",
    "text_id": "doc_addbc6a7f1dd_text_000007",
    "text": "Viewers often struggle to extract key information from lengthy videos.",
    "page_number": 1,
    "bounding_box": {
      "left": 36.12,
      "top": 2622.3500000000004,
      "right": 822.1808400000001,
      "bottom": 2538.7099999999996
    },
    "label": "list_item"
  },
  {
