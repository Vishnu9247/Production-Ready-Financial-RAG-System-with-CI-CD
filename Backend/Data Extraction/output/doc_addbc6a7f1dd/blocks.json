    "type": "heading",
    "text_id": "doc_addbc6a7f1dd_text_000030",
    "text": "Conclusion:",
    "heading_level": 1,
    "page_number": 1,
    "bounding_box": {
      "left": 1483.99,
      "top": 1019.01,
      "right": 1666.46788,
